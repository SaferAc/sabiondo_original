<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        tools:context=".activity.MakeQuizz">




        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:text="Titulo"
            android:textStyle="bold"

            />

        <EditText
            android:id="@+id/et_quiztitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:hint="Escriba un titulo para el cuestionario"
            android:inputType="textPersonName"
            android:textAlignment="center" />

        <TextView
            android:id="@+id/tv_schoollevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Nivel educativo"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_shool_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:scrollbars="horizontal"
                app:singleLine="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip1"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:padding="12dp"
                    android:text="Primaria"
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_purple"
                    android:textSize="12sp"
                    app:chipBackgroundColor="@color/white"
                    app:chipStrokeColor="@android:color/holo_purple"
                    app:chipStrokeWidth="1dp"
                    app:chipSurfaceColor="@android:color/transparent" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip2"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:padding="12dp"
                    android:text="Secundaria"
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_blue_light"
                    android:textSize="12sp"
                    app:chipBackgroundColor="@color/white"
                    app:chipStrokeColor="@android:color/holo_blue_light"
                    app:chipStrokeWidth="1dp"
                    app:chipSurfaceColor="@android:color/transparent" />


                <com.google.android.material.chip.Chip
                    android:id="@+id/chip3"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:padding="12dp"
                    android:text="Otro"
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_red_light"
                    android:textSize="12sp"
                    app:chipBackgroundColor="@color/white"
                    app:chipStrokeColor="@android:color/holo_red_light"
                    app:chipStrokeWidth="1dp"
                    app:chipSurfaceColor="@android:color/transparent" />


            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/line_spc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:weightSum="2">


            <TextView
                android:id="@+id/tv_school_level_spc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:layout_weight="1"
                android:text="Especifique:"
                android:textStyle="bold" />


            <EditText
                android:id="@+id/et_spc_school_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:hint="Nivel educativo"
                android:textAlignment="center" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/line_spcgrade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:weightSum="2">


            <TextView
                android:id="@+id/tv_grade_spc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:layout_weight="1"
                android:text="Grado:"
                android:textAlignment="center"
                android:textStyle="bold" />


            <EditText
                android:id="@+id/et_spc_school_grade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:hint="Grado"
                android:inputType="number"
                android:textAlignment="center" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/line_grade"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_grade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Grado"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_grade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:scrollbars="horizontal"
                app:chipSpacingVertical="16dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip4"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_marginBottom="8dp"
                    android:padding="12dp"
                    android:text="1°"

                    android:textAlignment="center"
                    android:textColor="@android:color/holo_green_light"
                    android:textSize="14sp"
                    app:chipBackgroundColor="@color/white"
                    app:chipStrokeColor="@android:color/holo_green_light"
                    app:chipStrokeWidth="1dp"
                    app:chipSurfaceColor="@android:color/transparent" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip5"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_marginBottom="8dp"
                    android:padding="12dp"
                    android:text="2°"
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_orange_light"
                    android:textSize="14sp"
                    app:chipBackgroundColor="@color/white"
                    app:chipStrokeColor="@android:color/holo_orange_light"
                    app:chipStrokeWidth="1dp"
                    app:chipSurfaceColor="@android:color/transparent" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip6"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_marginBottom="8dp"
                    android:padding="12dp"
                    android:text="3°"
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_blue_light"
                    android:textSize="14sp"
                    app:chipBackgroundColor="@color/white"
                    app:chipStrokeColor="@android:color/holo_blue_light"
                    app:chipStrokeWidth="1dp"
                    app:chipSurfaceColor="@android:color/transparent" />


                <com.google.android.material.chip.Chip
                    android:id="@+id/chip7"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_marginBottom="8dp"
                    android:padding="12dp"
                    android:text="4°"
                    android:textAlignment="center"

                    android:textColor="@android:color/holo_orange_dark"
                    android:textSize="14sp"

                    app:chipBackgroundColor="@color/white"
                    app:chipStrokeColor="@android:color/holo_orange_dark"
                    app:chipStrokeWidth="1dp"
                    app:chipSurfaceColor="@android:color/transparent" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip8"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_marginBottom="8dp"
                    android:padding="12dp"
                    android:text="5°"

                    android:textAlignment="center"
                    android:textColor="@android:color/holo_purple"
                    android:textSize="14sp"

                    app:chipBackgroundColor="@color/white"

                    app:chipStrokeColor="@android:color/holo_purple"
                    app:chipStrokeWidth="1dp"
                    app:chipSurfaceColor="@android:color/transparent" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip9"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_marginBottom="8dp"
                    android:padding="12dp"
                    android:text="6°"
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_red_light"
                    android:textSize="14sp"
                    app:chipBackgroundColor="@color/white"
                    app:chipStrokeColor="@android:color/holo_red_light"
                    app:chipStrokeWidth="1dp"
                    app:chipSurfaceColor="@android:color/transparent" />


            </com.google.android.material.chip.ChipGroup>

            <TextView
                android:id="@+id/tv_trimestre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Trimeste"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_trimestre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:scrollbars="horizontal"
                app:chipSpacingVertical="16dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip13"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_marginBottom="8dp"
                    android:padding="12dp"
                    android:text="1"
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_blue_bright"
                    android:textSize="14sp"
                    app:chipBackgroundColor="@color/white"
                    app:chipStrokeColor="@android:color/holo_blue_bright"
                    app:chipStrokeWidth="1dp"
                    app:chipSurfaceColor="@android:color/transparent" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip14"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_marginBottom="8dp"
                    android:padding="12dp"
                    android:text="2"
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_orange_dark"
                    android:textSize="14sp"
                    app:chipBackgroundColor="@color/white"
                    app:chipStrokeColor="@android:color/holo_orange_dark"
                    app:chipStrokeWidth="1dp"
                    app:chipSurfaceColor="@android:color/transparent" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip15"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_marginBottom="8dp"
                    android:padding="12dp"
                    android:text="3"
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_green_dark"
                    android:textSize="14sp"
                    app:chipBackgroundColor="@color/white"
                    app:chipStrokeColor="@android:color/holo_green_dark"
                    app:chipStrokeWidth="1dp"
                    app:chipSurfaceColor="@android:color/transparent" />


            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>

        <TextView

            android:id="@+id/tv_timeset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Limite de tiempo"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:scrollbars="horizontal"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip10"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginBottom="8dp"
                android:padding="12dp"
                android:text="30"
                android:textAlignment="center"
                android:textColor="@android:color/holo_red_light"
                android:textSize="12sp"
                app:chipBackgroundColor="@android:color/white"
                app:chipStrokeColor="@android:color/holo_red_light"

                app:chipStrokeWidth="1dp"
                app:chipSurfaceColor="@android:color/transparent" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip11"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginBottom="8dp"
                android:padding="12dp"
                android:text="40"
                android:textAlignment="center"
                android:textColor="@android:color/holo_blue_light"
                android:textSize="12sp"
                app:chipBackgroundColor="@android:color/white"
                app:chipStrokeColor="@android:color/holo_blue_light"
                app:chipStrokeWidth="1dp"
                app:chipSurfaceColor="@android:color/transparent" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip12"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginBottom="8dp"
                android:padding="12dp"
                android:text="99"
                android:textAlignment="center"
                android:textColor="@android:color/holo_purple"
                android:textSize="12sp"
                app:chipBackgroundColor="@android:color/white"
                app:chipStrokeColor="@android:color/holo_purple"
                app:chipStrokeWidth="1dp"
                app:chipSurfaceColor="@android:color/transparent" />


        </com.google.android.material.chip.ChipGroup>

        <TextView

            android:id="@+id/tv_question"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Editar preguntas"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center">

            <TextView
                android:id="@+id/num_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/white_circle_drawable"
                android:gravity="center"
                android:text="1"
                android:textColor="#ff2800" />

            <TextView
                android:id="@+id/num_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/white_circle_drawable"
                android:gravity="center"
                android:text="2"
                android:textColor="#ff2800" />

            <TextView
                android:id="@+id/num_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/white_circle_drawable"
                android:gravity="center"
                android:text="3"
                android:textColor="#ff2800" />

            <TextView
                android:id="@+id/num_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/white_circle_drawable"
                android:gravity="center"
                android:text="4"
                android:textColor="#ff2800" />

            <TextView
                android:id="@+id/num_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/white_circle_drawable"
                android:gravity="center"
                android:text="5"
                android:textColor="#ff2800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center">

            <TextView
                android:id="@+id/num_6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/white_circle_drawable"
                android:gravity="center"
                android:text="6"
                android:textColor="#ff2800" />

            <TextView
                android:id="@+id/num_7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/white_circle_drawable"
                android:gravity="center"
                android:text="7"
                android:textColor="#ff2800" />

            <TextView
                android:id="@+id/num_8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/white_circle_drawable"
                android:gravity="center"
                android:text="8"
                android:textColor="#ff2800" />

            <TextView
                android:id="@+id/num_9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/white_circle_drawable"
                android:gravity="center"
                android:text="9"
                android:textColor="#ff2800" />

            <TextView
                android:id="@+id/num_10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/white_circle_drawable"
                android:gravity="center"
                android:text="10"
                android:textColor="#ff2800" />


        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_createquiz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            app:cardBackgroundColor="@color/green_A400"
            android:layout_marginTop="@dimen/play_margin"
            app:cardCornerRadius="8dp">

            <RelativeLayout
                android:layout_margin="5dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                >

                    <TextView
                        android:id="@+id/btnOpt12"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:padding="5dp"
                        android:text="Crear"
                        android:scrollHorizontally="true"
                        android:textSize="18sp"
                        android:textColor="@color/white" />


            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_addquestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            app:cardBackgroundColor="@color/blue_A200"
            android:layout_marginTop="@dimen/play_margin"
            app:cardCornerRadius="8dp">

            <RelativeLayout

                android:layout_margin="5dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:padding="5dp"
                    android:text="Agregar Pregunta"
                    android:scrollHorizontally="true"
                    android:textSize="18sp"
                    android:textColor="@color/white" />


            </RelativeLayout>
        </androidx.cardview.widget.CardView>


    </LinearLayout>
</ScrollView>